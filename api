export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') { res.status(200).end(); return; }
  if (req.method !== 'POST') { res.status(405).json({error: 'Method not allowed'}); return; }
  try {
    const { messages } = req.body;
    const response = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer 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'
      },
      body: JSON.stringify({ model: 'gpt-4o-mini', max_tokens: 500, messages })
    });
    const data = await response.json();
    res.status(200).json(data);
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
}
